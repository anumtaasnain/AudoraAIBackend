          }
        },
        {
          "name": "Update Lead Status → viewed",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/sponsors/leads/{{leadId}}/status", "host": ["{{baseUrl}}"], "path": ["sponsors", "leads", "{{leadId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"viewed\"\n}" }
          }
        },
        {
          "name": "Update Lead Status → contacted",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/sponsors/leads/{{leadId}}/status", "host": ["{{baseUrl}}"], "path": ["sponsors", "leads", "{{leadId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"contacted\"\n}" }
          }
        },
        {
          "name": "Update Lead Status → converted",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/sponsors/leads/{{leadId}}/status", "host": ["{{baseUrl}}"], "path": ["sponsors", "leads", "{{leadId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"converted\"\n}" }
          }
        },
