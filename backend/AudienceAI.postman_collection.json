    {
      "name": "💼 Sponsors",
      "item": [
        {
          "name": "Generate Leads (run once after seed)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/sponsors/generate-leads", "host": ["{{baseUrl}}"], "path": ["sponsors", "generate-leads"] }
          }
        },
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sponsors/leads?page=1&limit=20",
              "host": ["{{baseUrl}}"], "path": ["sponsors", "leads"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Filter — Hot Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sponsors/leads?quality=hot",
              "host": ["{{baseUrl}}"], "path": ["sponsors", "leads"],
              "query": [{ "key": "quality", "value": "hot" }]
            }
          }
        },
        {
          "name": "Filter — Warm Leads",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/sponsors/leads?quality=warm",
              "host": ["{{baseUrl}}"], "path": ["sponsors", "leads"],
