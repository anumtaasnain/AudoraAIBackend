{
  "info": {
    "name": "AudienceAI API",
    "description": "Complete Postman collection for the AudienceAI backend API. Import this file into Postman along with AudienceAI.postman_environment.json.\n\n**How to use:**\n1. Import both JSON files into Postman.\n2. Select the 'AudienceAI' environment.\n3. Run 'Auth > Login' first — the access token is captured automatically.\n4. All subsequent requests will use the token from the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register (Attendee)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "  pm.test('Registered successfully', () => pm.expect(pm.response.code).to.eql(201));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@test.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+1 (555) 999-0000\",\n  \"company\": \"Test Corp\",\n  \"jobTitle\": \"Chief Technology Officer\",\n  \"industry\": \"technology\",\n  \"companySize\": \"201-500\",\n  \"eventInterest\": \"ai-ml\",\n  \"hearAboutUs\": \"referral\"\n}"
            }
          }
        },

        {
          "name": "Login (Organizer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "  pm.test('Login successful', () => pm.expect(pm.response.code).to.eql(200));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@audienceai.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },

        {
          "name": "Login (Sponsor)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "  pm.test('Login successful', () => pm.expect(pm.response.code).to.eql(200));",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sponsor@dataflow.io\",\n  \"password\": \"password123\"\n}"
            }
          }
        },

        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@audienceai.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },

        {
          "name": "Login (Attendee)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sarah.chen@techcorp.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },

        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('accessToken',  json.data.accessToken);",
            "  pm.environment.set('refreshToken', json.data.refreshToken);",
            "  pm.collectionVariables.set('accessToken',  json.data.accessToken);",
            "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },

        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobTitle\": \"VP of Engineering\",\n  \"company\": \"Updated Corp\",\n  \"companySize\": \"1000+\"\n}"
            }
          }
        },
        {
          "name": "Delete My Account",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users", "me"] }
          }
        },
        {
          "name": "List All Users (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20",
              "host": ["{{baseUrl}}"], "path": ["users"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Get User by ID (Admin)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        }
      ]
    },

    {
      "name": "🧑‍💼 Attendees",
      "item": [
        {
          "name": "List All Attendees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendees?page=1&limit=20",
              "host": ["{{baseUrl}}"], "path": ["attendees"],
              "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Filter — High Relevance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendees?status=high",
              "host": ["{{baseUrl}}"], "path": ["attendees"],
              "query": [{ "key": "status", "value": "high" }]
            }
          }
        },
        {
          "name": "Filter — Moderate Relevance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendees?status=moderate",
              "host": ["{{baseUrl}}"], "path": ["attendees"],
              "query": [{ "key": "status", "value": "moderate" }]
            }
          }
        },
        {
          "name": "Filter — Low Relevance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendees?status=low",
              "host": ["{{baseUrl}}"], "path": ["attendees"],
              "query": [{ "key": "status", "value": "low" }]
            }
          }
        },
        {
          "name": "Search Attendees",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendees?search=sarah",
              "host": ["{{baseUrl}}"], "path": ["attendees"],
              "query": [{ "key": "search", "value": "sarah" }]
            }
          }
        },
        {
          "name": "Get Attendee by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/attendees/{{attendeeId}}", "host": ["{{baseUrl}}"], "path": ["attendees", "{{attendeeId}}"] }
          }
        },
        {
          "name": "Get Attendee AI Score",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/attendees/{{attendeeId}}/score", "host": ["{{baseUrl}}"], "path": ["attendees", "{{attendeeId}}", "score"] }
          }
        }
      ]
    },

    {
      "name": "📅 Events",
      "item": [
        {
          "name": "List Active Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] }
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["events", "{{eventId}}"] }
          }
        },
        {
          "name": "Create Event (Organizer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  const json = pm.response.json();",
            "  pm.environment.set('eventId', json.data._id);",
            "  pm.collectionVariables.set('eventId', json.data._id);",
            "}"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/events", "host": ["{{baseUrl}}"], "path": ["events"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cloud Summit 2026\",\n  \"description\": \"Premier cloud computing conference.\",\n  \"eventType\": \"cloud\",\n  \"location\": \"New York, NY\",\n  \"startsAt\": \"2026-09-20T09:00:00Z\",\n  \"endsAt\":   \"2026-09-22T18:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Update Event (Organizer)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["events", "{{eventId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cloud Summit 2026 — Updated\",\n  \"location\": \"San Francisco, CA\"\n}"
            }
          }
        },
        {
          "name": "Delete Event (Organizer)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["events", "{{eventId}}"] }
          }
        },
        {
          "name": "Register for Event (Attendee)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/events/{{eventId}}/register", "host": ["{{baseUrl}}"], "path": ["events", "{{eventId}}", "register"] }
          }
        }
      ]
    },

